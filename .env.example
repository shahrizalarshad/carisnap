# =============================================================================
# CariSnap — Environment Configuration
# Copy to .env and adjust per environment. See DEPLOYMENT.md for production.
# =============================================================================

APP_NAME=CariSnap
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (Sail uses MySQL; production: managed MySQL 8) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# --- Session / Cache / Queue (production: prefer redis) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# --- Redis (Sail: redis service; production: managed Redis) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
# Local (Sail): Mailpit — open http://localhost:8025
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@carisnap.test"
MAIL_FROM_NAME="${APP_NAME}"

# Production: Resend
# MAIL_MAILER=resend
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM_ADDRESS="hello@carisnap.my"

# --- Media storage (Spatie Media Library) ---
# Local (Sail): MinIO S3-compatible API
FILESYSTEM_DISK=s3
MEDIA_DISK=s3

AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=local
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/local

# Production: Cloudflare R2 (S3-compatible — same disk driver)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=carisnap-media
# AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# AWS_URL=https://media.carisnap.my

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# --- Horizon (queue dashboard — protect in production) ---
HORIZON_PATH=horizon

# --- Frontend ---
VITE_APP_NAME="${APP_NAME}"
